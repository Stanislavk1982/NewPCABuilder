<Window x:Class="ImageClusterizer_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ImageClusterizer_WPF.ViewModels"
        Title="ImageClusterizer" Height="800" Width="1200" MinHeight="600" MinWidth="900"
        Background="{DynamicResource AppBackground}">
    <DockPanel>
        <!-- ToolBar -->
        <ToolBarTray DockPanel.Dock="Top" Background="{DynamicResource ToolBarBackground}">
            <ToolBar>
                <TextBlock Text="Folder:" Foreground="{DynamicResource AppText}" VerticalAlignment="Center" Margin="4,0"/>
                <TextBox Width="300" Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource AppSurface}" Foreground="{DynamicResource AppText}"
                         BorderBrush="{DynamicResource AppBorder}" Padding="4,2" VerticalContentAlignment="Center"/>
                <ComboBox Width="100" ItemsSource="{Binding VectorTypes}" SelectedItem="{Binding SelectedVectorType}"
                          Background="{DynamicResource AppSurface}" Foreground="{DynamicResource AppText}" Margin="4,0"/>
                <Button Content="Scan" Command="{Binding ScanCommand}"
                        Background="{DynamicResource AppAccent}" Foreground="White" Padding="8,4" Margin="2,0"
                        BorderThickness="0"/>
                <Button Content="Cancel" Command="{Binding CancelScanCommand}"
                        Background="{DynamicResource IndicatorWarning}" Foreground="White" Padding="8,4" Margin="2,0"
                        BorderThickness="0" IsEnabled="{Binding IsScanning}"/>
                <Separator/>
                <Button Content="🗑 Clear Data" Command="{Binding ClearAllDataCommand}"
                        Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}"
                        Padding="8,4" Margin="2,0" BorderThickness="0"/>
                <Separator/>
                <Button Content="{Binding ThemeLabel, FallbackValue='Dark'}" Command="{Binding ToggleThemeCommand}"
                        Background="{DynamicResource AppAccent}" Foreground="White"
                        Padding="8,4" Margin="2,0" BorderThickness="0"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Status Bar -->
        <DockPanel DockPanel.Dock="Bottom" Height="24"
                   Background="{DynamicResource StatusBarBackground}" LastChildFill="False">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="8,0">
                <TextBlock Foreground="White" FontSize="11">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Images: {0} | Clusters: {1} | {2}">
                            <Binding Path="VectorCount"/>
                            <Binding Path="ClusterCount"/>
                            <Binding Path="SelectedVectorType"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0">
                <Ellipse Width="8" Height="8" Margin="0,0,4,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource IndicatorInactive}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding GpuAvailable}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource IndicatorActive}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding GpuName}" Foreground="White" FontSize="11" Margin="0,0,8,0"/>
                <TextBlock Text="|" Foreground="White" FontSize="11" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding DatabaseSizeText}" Foreground="White" FontSize="11"/>
            </StackPanel>
        </DockPanel>

        <!-- Cockpit Advanced Panel -->
        <Expander DockPanel.Dock="Top" Header="Advanced Settings"
                  IsExpanded="{Binding IsCockpitExpanded}"
                  Background="{DynamicResource AppSurface}"
                  Foreground="{DynamicResource AppText}"
                  BorderBrush="{DynamicResource AppBorder}">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <!-- Group A: Hardware -->
                <StackPanel Grid.Column="0" Margin="4">
                    <TextBlock Text="Compute Hardware" FontWeight="Bold" Foreground="{DynamicResource AppText}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource IndicatorInactive}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding GpuAvailable}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource IndicatorActive}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding GpuName}" Foreground="{DynamicResource AppText}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <CheckBox Content="Use GPU" IsChecked="{Binding UseGpu}" Foreground="{DynamicResource AppText}"
                              IsEnabled="{Binding GpuAvailable}"/>
                </StackPanel>
                <!-- Group B: Sparse -->
                <StackPanel Grid.Column="1" Margin="4">
                    <TextBlock Text="Vector Compression" FontWeight="Bold" Foreground="{DynamicResource AppText}"/>
                    <Slider Minimum="8" Maximum="2048" Value="{Binding SparseTopN}"
                            TickFrequency="128" IsSnapToTickEnabled="False" Width="160"/>
                    <TextBlock Foreground="{DynamicResource AppTextSecondary}" FontSize="11">
                        <TextBlock.Text>
                            <Binding Path="SparseTopN" StringFormat="Top-{0} / 2048"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
                <!-- Group C: Clustering -->
                <StackPanel Grid.Column="2" Margin="4">
                    <TextBlock Text="Clustering" FontWeight="Bold" Foreground="{DynamicResource AppText}"/>
                    <Slider Minimum="0.50" Maximum="0.99" Value="{Binding SimilarityThreshold}"
                            TickFrequency="0.05" Width="160"/>
                    <TextBlock Foreground="{DynamicResource AppTextSecondary}" FontSize="11">
                        <TextBlock.Text>
                            <Binding Path="SimilarityThreshold" StringFormat="Similarity: {0:F2}"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
                <!-- Group D: Telemetry -->
                <StackPanel Grid.Column="3" Margin="4">
                    <TextBlock Text="Telemetry" FontWeight="Bold" Foreground="{DynamicResource AppText}"/>
                    <TextBlock Foreground="{DynamicResource AppTextSecondary}" FontSize="11">
                        <TextBlock.Text><Binding Path="VectorCount" StringFormat="Images: {0}"/></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource AppTextSecondary}" FontSize="11">
                        <TextBlock.Text><Binding Path="ClusterCount" StringFormat="Clusters: {0}"/></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource AppTextSecondary}" FontSize="11">
                        <TextBlock.Text><Binding Path="DatabaseSizeText" StringFormat="DB: {0}"/></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource AppTextSecondary}" FontSize="11">
                        <TextBlock.Text><Binding Path="LastScanDuration" StringFormat="Last scan: {0}"/></TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Expander>

        <!-- Console Log Panel -->
        <Expander DockPanel.Dock="Bottom" IsExpanded="{Binding IsConsoleExpanded}"
                  Background="{DynamicResource ConsoleBackground}"
                  Foreground="{DynamicResource ConsoleForeground}"
                  BorderBrush="{DynamicResource AppBorder}" x:Name="ConsoleExpander">
            <Expander.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Console" Foreground="{DynamicResource ConsoleForeground}" FontFamily="Consolas" FontSize="11"/>
                    <Button Content="Clear" Margin="8,0,0,0" FontSize="10" Padding="4,1"
                            Click="ClearConsole_Click"/>
                </StackPanel>
            </Expander.Header>
            <ScrollViewer x:Name="ConsoleScrollViewer" Height="120" HorizontalScrollBarVisibility="Auto"
                          Background="{DynamicResource ConsoleBackground}">
                <ItemsControl ItemsSource="{Binding ConsoleLines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                       Foreground="{DynamicResource ConsoleForeground}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Expander>

        <!-- Progress bars -->
        <ProgressBar DockPanel.Dock="Top" Height="4" Value="{Binding ScanProgress}"
                     Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"
                     Foreground="{DynamicResource AppAccent}" Background="Transparent" BorderThickness="0"/>

        <!-- Main Content: Tabs -->
        <TabControl Background="{DynamicResource AppBackground}"
                    Foreground="{DynamicResource AppText}"
                    BorderBrush="{DynamicResource AppBorder}">
            <!-- Tab 1: Map -->
            <TabItem Header="Map" Background="{DynamicResource AppSurface}"
                     Foreground="{DynamicResource AppText}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,4"
                                Background="{DynamicResource AppSurface}">
                        <Button Content="Recalculate PCA" Command="{Binding RecalculatePcaCommand}"
                                Background="{DynamicResource AppAccent}" Foreground="White"
                                Padding="8,4" BorderThickness="0" Margin="0,0,8,0"/>
                        <ProgressBar Width="100" Height="16" Value="{Binding PcaProgress}"
                                     Visibility="{Binding IsPcaComputing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock Margin="4,0" VerticalAlignment="Center" Foreground="{DynamicResource AppText}">
                            <TextBlock.Text>
                                <Binding Path="PcaProgress" StringFormat="{}{0}%"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ImageItems}"
                                      Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="{Binding DataContext.CanvasWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            Height="{Binding DataContext.CanvasHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style>
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="32" Height="32" CornerRadius="2"
                                            BorderBrush="{DynamicResource AppAccent}"
                                            BorderThickness="1">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <StackPanel>
                                                    <Image Source="{Binding ThumbnailPath}" Width="112" Height="112"/>
                                                    <TextBlock Text="{Binding FilePath}" FontSize="10" TextWrapping="Wrap" MaxWidth="200"/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Tab 2: Clusters -->
            <TabItem Header="Clusters" Background="{DynamicResource AppSurface}"
                     Foreground="{DynamicResource AppText}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,4"
                                Background="{DynamicResource AppSurface}">
                        <Button Content="Compute Clusters" Command="{Binding ComputeClustersCommand}"
                                Background="{DynamicResource AppAccent}" Foreground="White"
                                Padding="8,4" BorderThickness="0" Margin="0,0,8,0"/>
                        <ProgressBar Width="100" Height="16" IsIndeterminate="True"
                                     Visibility="{Binding IsClusterComputing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="16" FontSize="14"
                               Foreground="{DynamicResource AppTextSecondary}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Text="Click 'Compute Clusters' to group similar images.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ClusterCount}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Clusters}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4" Padding="6" CornerRadius="4"
                                            Background="{DynamicResource AppSurface}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1" Width="180">
                                        <StackPanel>
                                            <TextBlock Foreground="{DynamicResource AppText}" FontWeight="Bold"
                                                       FontSize="11">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Cluster {0} ({1} images)">
                                                        <Binding Path="ClusterId"/>
                                                        <Binding Path="Images.Count"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <ItemsControl ItemsSource="{Binding Images}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Image Source="{Binding ThumbnailPath}"
                                                               Width="40" Height="40" Margin="2"
                                                               Stretch="UniformToFill"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
