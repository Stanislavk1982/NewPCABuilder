<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackground"        Color="#1E1E1E"/>
    <SolidColorBrush x:Key="AppSurface"           Color="#252526"/>
    <SolidColorBrush x:Key="AppBorder"            Color="#3F3F46"/>
    <SolidColorBrush x:Key="AppText"              Color="#D4D4D4"/>
    <SolidColorBrush x:Key="AppTextSecondary"     Color="#808080"/>
    <SolidColorBrush x:Key="AppAccent"            Color="#007ACC"/>
    <SolidColorBrush x:Key="AppAccentHover"       Color="#1C97EA"/>
    <SolidColorBrush x:Key="ToolBarBackground"    Color="#2D2D30"/>
    <SolidColorBrush x:Key="StatusBarBackground"  Color="#007ACC"/>
    <SolidColorBrush x:Key="ConsoleBackground"    Color="#0C0C0C"/>
    <SolidColorBrush x:Key="ConsoleForeground"    Color="#00FF41"/>
    <SolidColorBrush x:Key="IndicatorActive"      Color="#00C853"/>
    <SolidColorBrush x:Key="IndicatorInactive"    Color="#424242"/>
    <SolidColorBrush x:Key="IndicatorWarning"     Color="#FFB300"/>
</ResourceDictionary>
